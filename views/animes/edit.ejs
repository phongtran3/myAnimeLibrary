<h2>Edit Anime</h2>
<% if (locals.errorMessage != null) { %>
    <div class="error-message">
        <%= errorMessage %>
    </div>
    <% } %>
        <form action="/anime/<%= anime.id %>?_method=PUT" method="POST">
            <%- include('_form_fields'), {anime: anime}%>
                <a href="/">Cancel</a>
                <button type="submit">Update</button>
        </form>