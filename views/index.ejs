<h2>Search Anime</h2>
<form action="/" method="GET">
    <div>
        <label>Title</label>
        <input type="text" name="title" value="<% searchOpt.title %>" placeholder="Search">
    </div>
    <%- include('partials/genre_theme.ejs', {anime: anime}) %>
        <button type="submit">Search</button>
</form>
<br>
<div>
    <% anime.forEach(anime => { %>
        <a href="/anime/<%= anime.id%>">
        <img height="150" width="100" src="<%= anime.coverImagePath %>">
        <% }) %>
        </a>
</div>

<form action="/logout?_method=DELETE" method="POST">
    <button type="submit">Log Out</button>
</form>